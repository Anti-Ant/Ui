local function DoAutoWorkout(amount)
    while Library.flags.Enabled and task.wait() do
        if Workout then
            Workout:FireServer(amount)
        else
            Notification("Missing Data", "Click workout manually once to capture remote!")
            task.wait(2) -- Prevent spamming notifications
        end
    end
end

