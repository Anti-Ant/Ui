--// Send Notification \\--
function Notification(title, text)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = title,
            Text = text,
            Duration = 6
        })
    end)
end

--// Dynamic Workout Remote Capture \\--
local Workout = nil

local MT = getrawmetatable(game)
local OldNameCall = MT.__namecall
setreadonly(MT, false)

MT.__namecall = newcclosure(function(self, ...)
    local Method = getnamecallmethod()
    local Args = {...}
    
    -- When the game naturally fires a RemoteEvent with a number, capture it
    if not checkcaller() and Method == "FireServer" and self:IsA("RemoteEvent") then
        if type(Args[1]) == "number" then
            Workout = self
            print("Captured Workout Remote: " .. Workout.Name)
            Notification("Captured!", "Workout Remote Found.")
        end
    end
    
    return OldNameCall(self, ...)
end)
setreadonly(MT, true)

--// Helper Functions \\--
function GetGoal()
    for _, A_1 in next, Areas:GetChildren() do
        local Goal = A_1:FindFirstChild("Goal", true)
        if Goal and Goal:FindFirstChildWhichIsA("TouchTransmitter") then
            return Goal
        end
    end
    return false
end

local function ClickWorkout(amount)
    if Workout then
        Workout:FireServer(amount)
    else
        Notification("Missing Data", "Click workout manually once to capture remote!")
    end
end

