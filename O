--// Get Goal \\--
local Areas = Workspace:WaitForChild("Areas")
function GetGoal()
    for _, A_1 in next, Areas:GetChildren() do
        local Goal = A_1:FindFirstChild("Goal", true)
        if Goal and Goal:FindFirstChildWhichIsA("TouchTransmitter") then
            return Goal
        end
    end
    return false
end

